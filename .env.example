# ⚡ VEAM: Environment Configuration Template

# --- Asaas Gateway ---
ASAAS_API_KEY=your_asaas_api_key_here
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3
ASAAS_WEBHOOK_SECRET=your_asaas_webhook_secret_here

# --- Mercado Pago Gateway ---
MP_ACCESS_TOKEN=your_mp_access_token_here
MP_WEBHOOK_SECRET=your_mp_webhook_secret_here

# --- Database (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=veam_db
# DSN format for CLI and Migrations
DATABASE_URL=postgres://postgres:postgres@localhost:5432/veam_db?sslmode=disable

# --- Engine & Resilience ---
HTTP_PORT=8080
LOG_LEVEL=info
MAX_RETRIES=5
WORKER_BATCH_SIZE=10

# --- Observability (OpenTelemetry) ---
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=payment-engine
